# Copy to .env and adjust. Used by local runs and docker-compose.

# A long random string. Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-long-random-string

# Comma-separated list of allowed frontend origins, or * for local dev.
# e.g. ALLOWED_ORIGINS=https://defects.jsp.mk
ALLOWED_ORIGINS=*

# Database. SQLite for quick local dev; Postgres for real/production use.
# docker-compose overrides this to point at the bundled Postgres service.
DATABASE_URL=sqlite:///./bus_defects.db

# First dispatcher account, created only when the user table is empty.
BOOTSTRAP_ADMIN_EMAIL=admin@jsp.mk
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# Password for the docker-compose Postgres service.
POSTGRES_PASSWORD=jsp_password
